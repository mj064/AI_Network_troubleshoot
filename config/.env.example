# Environment Configuration for Network Troubleshooting Assistant

# Application
ENVIRONMENT=production
DEBUG=False
PORT=5000

# Database
# For development: sqlite:///network_troubleshoot.db
# For production: postgresql://user:password@host:5432/network_troubleshoot
DATABASE_URL=sqlite:///network_troubleshoot.db

# File Upload
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE=16777216

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY=your-api-key-here

# API Configuration
API_URL=http://localhost:5000
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Features
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
